<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.gitlab.team_karmac1.KarmacDashboard</id>
  <name>Karmac Dashboard</name>
  <summary>Everything you need. Nothing you don't.</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <description>
    <p>
      Karmac is a free and open source desktop dashboard for Linux. It gives everyday
      users a beautiful, organized view of their system health and personal information
      without requiring any technical knowledge to set up or use.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Clock with mini calendar</li>
      <li>Weather with 3-day forecast (no API key required)</li>
      <li>Network speeds, ping/latency, and internet speed test</li>
      <li>CPU and GPU temperatures with configurable thresholds</li>
      <li>Fan speeds with Zero RPM detection</li>
      <li>CPU core activity and per-core frequency</li>
      <li>RAM and hard drive usage</li>
      <li>GPU usage and VRAM monitoring</li>
      <li>System power consumption</li>
      <li>Live FPS via MangoHud integration</li>
      <li>Network traffic by application</li>
      <li>Process monitor</li>
      <li>Disk I/O speeds</li>
      <li>Full hardware info in the sidebar</li>
    </ul>
    <p>
      Karmac is privacy-focused with no telemetry, no analytics, and no accounts required.
    </p>
  </description>

  <launchable type="desktop-id">io.gitlab.team_karmac1.KarmacDashboard.desktop</launchable>

